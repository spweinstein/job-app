# Supabase — All environments
# Supabase project API URL
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
# Supabase anonymous (public) API key
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# Supabase service role key — bypasses RLS. NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
# Postgres connection string — used in CI for migration push
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

# App — All environments
# Canonical public URL of the app (used in password reset redirectTo)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Resend — Edge Functions and webhooks
RESEND_API_KEY=re_<key>
RESEND_FROM_ADDRESS=noreply@example.com
RESEND_WEBHOOK_SECRET=<webhook-secret>

# Sentry — Server-side and client-side error reporting
SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
NEXT_PUBLIC_SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project-id>
# CI only — used for Sentry source map uploads
SENTRY_ORG=<org-slug>
SENTRY_PROJECT=<project-slug>
SENTRY_AUTH_TOKEN=<auth-token>

# Upstash Redis — Rate limiting (Vercel only)
UPSTASH_REDIS_REST_URL=https://<redis-url>.upstash.io
UPSTASH_REDIS_REST_TOKEN=<token>
